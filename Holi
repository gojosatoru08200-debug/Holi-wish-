<!DOCTYPE html>
<html>
<head>
<title>Happy Holi</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background: linear-gradient(-45deg, #ff4e50, #f9d423, #24c6dc, #e94057);
  background-size: 400% 400%;
  animation: gradient 8s ease infinite;
}

@keyframes gradient {
  0% {background-position: 0% 50%;}
  50% {background-position: 100% 50%;}
  100% {background-position: 0% 50%;}
}

.card {
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(15px);
  padding: 40px;
  border-radius: 20px;
  text-align: center;
  color: white;
  box-shadow: 0 0 30px rgba(0,0,0,0.3);
  width: 90%;
  max-width: 400px;
  animation: fadeIn 1.5s ease forwards;
}

h1 {
  font-size: 32px;
  margin-bottom: 10px;
  text-shadow: 0 0 15px rgba(255,255,255,0.8);
}

.business {
  font-size: 20px;
  font-weight: bold;
  margin-top: 20px;
}

.location {
  font-size: 16px;
  margin-top: 5px;
  opacity: 0.9;
}

button {
  margin-top: 20px;
  padding: 12px 25px;
  border: none;
  border-radius: 30px;
  font-size: 16px;
  cursor: pointer;
  background: white;
  color: #333;
  font-weight: bold;
}

@keyframes fadeIn {
  from {opacity: 0; transform: translateY(30px);}
  to {opacity: 1; transform: translateY(0);}
}
</style>
</head>

<body>

<div class="card" id="card">
  <button onclick="reveal()">🎁 Tap to Reveal Holi Wish</button>
</div>

<script>
function reveal() {
  document.getElementById("card").innerHTML = `
    <h1>🌈 Happy Holi 2026 🎉</h1>
    <div class="business">Mamupuria Electric and Engg Works</div>
    <div class="location">📍 Tohana, Haryana</div>
    <p style="margin-top:20px;">Wishing you a year filled with colors, success and happiness!</p>
  `;
}
</script>

</body>
</html>
